# ThinkStack Environment Variables

# Chatbot API Key for external integrations
CHATBOT_API_KEY=thinkstack_secret_123

# Gemini API Key
GEMINI_API_KEY=

# Firebase Configuration (Required if firebase-applet-config.json is not committed)
# Server-side
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_ID=(default)
# Client-side (Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=(default)

# Firebase Admin Service Account (Optional, JSON string)
# Required for standard production environments like Render if not using ADC
FIREBASE_SERVICE_ACCOUNT=
